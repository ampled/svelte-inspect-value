{
  "name": "inspect-monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ampled/svelte-inspect-value.git"
  },
  "homepage": "https://inspect.eirik.space",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm dev:docs && pnpm dev:sv",
    "dev:sv": "pnpm --filter './packages/*' dev",
    "dev:docs": "pnpm --filter './apps/*' dev",
    "build": "pnpm --filter '*' build",
    "preview": "pnpm --filter '*' preview",
    "format": "prettier --write .",
    "prettiercheck": "prettier --check .",
    "lint": "prettier --check . && eslint .",
    "lint:ci": "prettier --check . && eslint --max-warnings 1 .",
    "eslint": "eslint ."
  },
  "type": "module",
  "devDependencies": {
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-only-warn": "^1.2.0",
    "eslint-plugin-svelte": "^3.17.0",
    "prettier": "^3.8.1",
    "prettier-plugin-css-order": "^2.2.0",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte-eslint-parser": "^1.6.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.58.0"
  }
}
