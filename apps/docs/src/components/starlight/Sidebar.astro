---
import Default from '@astrojs/starlight/components/Sidebar.astro'
import GlobalOptions from '@components/global-opts/GlobalOptions.svelte'
---

<div class="sidebar not-content">
  <div class="default not-content">
    <Default />
  </div>

  <div class="opts not-content">
    <GlobalOptions client:only="svelte" transition:persist />
  </div>
</div>

<style>
  .sidebar {
    display: flex;
    position: relative;
    flex-direction: column;
    justify-content: space-between;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .default {
    /* background-color: darkblue; */
    height: 100%;
    overflow-y: auto;
  }

  .opts {
    /* background-color: black; */
    width: 100%;
    max-height: 200px;
    /* text-align: center; */
  }
</style>
